packages/backend/amplify/.amplify/
packages/backend/amplify/generated/

# generated graphql artifacts: ignored until intentionally committed in Phase 01
packages/api/src/generated/graphql/*
packages/api/src/generated/types/*
!packages/api/src/generated/graphql/.gitkeep
!packages/api/src/generated/types/.gitkeep
