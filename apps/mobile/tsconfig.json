{
  "extends": "@app/config/tsconfig/react-native.json",
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["react", "nativewind/types", "expo/types"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "app/**/*",
    "src/**/*",
    "*.ts",
    "*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "global.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": ["node_modules", ".expo", "dist", "ios", "android"]
}
